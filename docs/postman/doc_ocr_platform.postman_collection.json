            },
            "description": "Record the outcome of a webhook delivery attempt.\n\n`delivery_status` values:\n- `pending` — Delivery not yet attempted.\n- `retrying` — Attempt failed; will retry. Set `next_retry_at` to schedule next attempt.\n- `succeeded` — Webhook delivered successfully.\n- `failed` — All retry attempts exhausted.\n\nThe job's own `status` is unaffected by webhook delivery failure."
          },
          "response": [
            {
              "name": "200 OK — Succeeded",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {"key": "Authorization", "value": "Bearer {{internal_service_token}}"},
